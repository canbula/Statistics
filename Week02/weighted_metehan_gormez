import random

def weighted_srs(data, n, weights=None, with_replacement=False):
    # Eğer ağırlık (weights) verilmemişse
    if weights is None:
        if with_replacement:
            # İadeli, ağırlıksız seçim
            return random.choices(data, k=n)
        else:
            # İadesiz, ağırlıksız seçim
            return random.sample(data, n)
    
    # Eğer ağırlık (weights) verilmişse
    else:
        if with_replacement:
            # İadeli, ağırlıklı seçim
            return random.choices(data, weights=weights, k=n)
        else:
            
            return random.sample(data, n)
